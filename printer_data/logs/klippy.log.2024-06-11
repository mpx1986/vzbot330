spi_speed = 500000
spi_software_mosi_pin = PA7
spi_software_miso_pin = PA6
spi_software_sclk_pin = PA5
interpolate = false
run_current = 1.75
stealthchop_threshold = 0

[stepper_x1]
enable_pin = !PF15
step_pin = PG0
dir_pin = PG1
microsteps = 16
rotation_distance = 40
full_steps_per_rotation = 200

[tmc5160 stepper_x1]
cs_pin = PD11
spi_speed = 500000
spi_software_mosi_pin = PA7
spi_software_miso_pin = PA6
spi_software_sclk_pin = PA5
interpolate = false
run_current = 1.75
stealthchop_threshold = 0

[stepper_y]
enable_pin = !PG5
step_pin = PF11
dir_pin = !PG3
microsteps = 16
full_steps_per_rotation = 200
rotation_distance = 40
endstop_pin = !PG10
position_endstop = 0
position_max = 300
homing_speed = 100
homing_retract_dist = 0

[tmc5160 stepper_y]
cs_pin = PC6
spi_speed = 500000
spi_software_mosi_pin = PA7
spi_software_miso_pin = PA6
spi_software_sclk_pin = PA5
interpolate = false
run_current = 1.75
stealthchop_threshold = 0

[stepper_y1]
enable_pin = !PA2
step_pin = PG4
dir_pin = !PC1
microsteps = 16
full_steps_per_rotation = 200
rotation_distance = 40

[tmc5160 stepper_y1]
cs_pin = PC7
spi_speed = 500000
spi_software_mosi_pin = PA7
spi_software_miso_pin = PA6
spi_software_sclk_pin = PA5
interpolate = false
run_current = 1.75
stealthchop_threshold = 0

[stepper_z]
