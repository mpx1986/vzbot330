dir_pin = !PF12
microsteps = 16
full_steps_per_rotation = 200
rotation_distance = 40
endstop_pin = EBBCan: PC13
position_endstop = 0
position_max = 310
homing_speed = 100
homing_retract_dist = 0

[tmc5160 stepper_x]
